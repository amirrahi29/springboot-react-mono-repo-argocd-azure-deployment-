      "mainClass": "com.chat.app.ChatAppApplication",
      "projectName": "rahi-chat-backend",
      "cwd": "${workspaceFolder}/backend",
      "preLaunchTask": "backend: classes (includes frontend build)"
    },
    {
      "type": "java",
      "name": "Spring Boot (if workspaceFolder IS backend)",
      "request": "launch",
      "mainClass": "com.chat.app.ChatAppApplication",
      "projectName": "rahi-chat-backend",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "backend: classes (includes frontend build)"
    }
  ]
}
