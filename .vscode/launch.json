{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "ChatAppApplication",
      "request": "launch",
      "mainClass": "com.chat.app.ChatAppApplication",
      "projectName": ""
    },
    {
      "type": "java",
      "name": "Spring Boot (Gradle — open rahi-chat.code-workspace)",
